code start

room println(value):
    var _ = _native.io_println(value)
end;

// io.print Includes line breaks but is an explicit alias
room print(value):
    var _ = _native.io_print(value)
end;

room newline():
    var _ = _native.io_print("")
end;

room input(prompt):
    return _native.io_input(prompt)
end;

room dump(key, value):
    var _ = _native.io_println(key + " = " + value)
end;

room hr():
    var _ = _native.io_println("----------------------------------------")
end;
